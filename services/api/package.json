{
  "name": "@wa/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "./dist/server.js",
  "scripts": {
    "build": "tsup src/server.ts --format esm --target node20 --clean --sourcemap",
    "dev": "tsx watch src/server.ts",
    "start": "node dist/server.js",
    "clean": "rm -rf dist *.tsbuildinfo"
  },
  "dependencies": {
    "@wa/shared": "0.0.1",
    "fastify": "4.28.1",
    "ioredis": "5.4.1",
    "pg": "8.13.1",
    "pino": "9.5.0",
    "pino-pretty": "11.3.0",
    "prom-client": "^15.1.3",
    "zod": "3.23.8"
  },
  "devDependencies": {
    "@types/node": "20.14.10",
    "@types/pg": "8.11.10",
    "tsup": "8.3.5",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
  }
}
