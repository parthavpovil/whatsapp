# Postgres
DATABASE_URL=postgres://wa:wa_dev_password@localhost:5432/wa_service
POSTGRES_PASSWORD=wa_dev_password

# Redis
REDIS_URL=redis://localhost:6379

# api
PORT=8080
BACKEND_TO_WA_SHARED_SECRET=replace-me-with-32-bytes-of-random

# worker
WORKER_ID=worker-local-1
MAX_SESSIONS=10
MAX_RSS_MB=5000
PUPPETEER_EXECUTABLE_PATH=/usr/bin/chromium
WWEBJS_CACHE_DIR=./wwebjs-cache

# dispatcher
DISPATCHER_CONCURRENCY=4
DISPATCHER_HTTP_TIMEOUT_MS=10000

# S3-compatible object storage (R2, S3, MinIO)
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minio
S3_SECRET_ACCESS_KEY=minio_dev_password
S3_BUCKET=wa-media
S3_FORCE_PATH_STYLE=true

# Outbound media
OUTBOUND_MEDIA_ALLOWED_HOSTS=localhost,minio,r2.example.com
OUTBOUND_MEDIA_MAX_BYTES=16000000

# Rate limiting (per account)
RATELIMIT_CAPACITY=10
RATELIMIT_REFILL_PER_SEC=1

# Logging
LOG_LEVEL=info
